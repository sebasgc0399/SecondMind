rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      // C1 audit 2026-05 — enforce email_verified server-side. Google
      // sign-in marca email_verified=true automaticamente (D8 F47); para
      // email/password el banner client-side era solo UI nudge antes de
      // este fix. Sin grace period: zero users email/password no
      // verificados en prod al deploy (confirmado por user).
      allow read, write: if
        request.auth != null
        && request.auth.uid == userId
        && (request.auth.token.firebase.sign_in_provider == 'google.com'
            || request.auth.token.email_verified == true);
    }

    // F47.F6 — config/app: read público (LoginPage no tiene user
    // al verificar capacity). Writes solo via Admin SDK (triggers
    // onUserCreated/onUserDeleted) — client-side deny.
    //
    // Path explícito (no wildcard {configId}): si se agregan más docs
    // bajo /config/ (config/secrets, config/featureFlags, etc.), cada
    // uno requiere su propia regla en lugar de heredar read:true.
    match /config/app {
      allow read: if true;
      allow write: if false;
    }

    // F48 BYOK — userSecrets/: API keys cifradas del usuario. Deny-all
    // client-side; solo el Admin SDK (Cloud Functions) accede. Las rules
    // son aditivas (OR): si esto colgara de users/{userId}/{document=**}
    // (read/write owner), el cliente podría leer el ciphertext. Por eso
    // vive en colección top-level con regla propia. La metadata legible
    // (configured/last4) va en users/{uid}/settings/aiKeys.
    match /userSecrets/{userId}/{document=**} {
      allow read, write: if false;
    }
  }
}
