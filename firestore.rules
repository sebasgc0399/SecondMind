rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId}/{document=**} {
      // C1 audit 2026-05 — enforce email_verified server-side. Google
      // sign-in marca email_verified=true automaticamente (D8 F47); para
      // email/password el banner client-side era solo UI nudge antes de
      // este fix. Sin grace period: zero users email/password no
      // verificados en prod al deploy (confirmado por user).
      // SPEC-50 F4 (A-2) — beta cerrada por allowlist. En AND (nunca OR: las
      // rules son aditivas, un OR abriría de más) con C1: ademas de owner +
      // verificado, el email del token debe existir en allowlist/. Asume
      // token.email lowercase (Firebase normaliza email/pw; Google entrega
      // lowercase). Si falta o viene mixed-case, exists() falla → fail-closed.
      allow read, write: if
        request.auth != null
        && request.auth.uid == userId
        && (request.auth.token.firebase.sign_in_provider == 'google.com'
            || request.auth.token.email_verified == true)
        && exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email));
    }

    // F47.F6 / SPEC-53 — config/app: read público (LoginPage no tiene user
    // al leer signupsEnabled). Writes solo via Admin SDK (operador/Console) —
    // client-side deny. SPEC-53 removió el counter userCount y sus triggers;
    // config/app queda con { signupsEnabled, maxUsers }.
    //
    // Path explícito (no wildcard {configId}): si se agregan más docs
    // bajo /config/ (config/secrets, config/featureFlags, etc.), cada
    // uno requiere su propia regla en lugar de heredar read:true.
    match /config/app {
      allow read: if true;
      allow write: if false;
    }

    // F48 BYOK — userSecrets/: API keys cifradas del usuario. Deny-all
    // client-side; solo el Admin SDK (Cloud Functions) accede. Las rules
    // son aditivas (OR): si esto colgara de users/{userId}/{document=**}
    // (read/write owner), el cliente podría leer el ciphertext. Por eso
    // vive en colección top-level con regla propia. La metadata legible
    // (configured/last4) va en users/{uid}/settings/aiKeys.
    match /userSecrets/{userId}/{document=**} {
      allow read, write: if false;
    }

    // SPEC-50 F4 (A-2) — allowlist/: emails invitados a la beta cerrada.
    // Deny-all client-side (mismo patrón que userSecrets/): las rules la leen
    // server-side vía exists() en users/**, pero el cliente NUNCA la lee
    // (evita exponer los ~100 emails como PII). Gestión manual del operador
    // (consola/script), doc IDs en lowercase+trim. La existencia del doc ES el
    // flag (sin payload, opcionalmente { addedAt } para auditoría).
    match /allowlist/{email} {
      allow read, write: if false;
    }

    // SPEC-51 F7 (A-3) — rateLimits/: contadores de rate-limit por uid+key+ventana
    // (embedQuery, etc.). Deny-all client-side (mismo patrón que allowlist/userSecrets):
    // solo el Admin SDK (Cloud Functions) los lee/escribe. La TTL sobre el campo
    // expireAt purga slots viejos (config GCP, no acá).
    match /rateLimits/{document=**} {
      allow read, write: if false;
    }

    // SPEC-52 F1 — accessRequests/: cola del formulario público de solicitud de
    // acceso. Deny-all client-side (mismo patrón que allowlist/userSecrets/rateLimits):
    // submit (público), list y process pasan SIEMPRE por Cloud Functions (el Admin
    // SDK bypassa). El cliente NUNCA la lee ni escribe directo — guarda emails de
    // solicitantes (PII), mismo cuidado que A-3 dio a la allowlist. Doc id = email
    // normalizado (trim+lowercase) para dedup natural.
    match /accessRequests/{id} {
      allow read, write: if false;
    }

    // SPEC consent server-authoritative — consentLog/: evidencia del consentimiento
    // de búsqueda semántica (§7.1). Deny-all client-side (mismo patrón que
    // userSecrets/allowlist/rateLimits/accessRequests): solo el Admin SDK (Cloud
    // Functions: markSemanticConsent + onSemanticConsentChanged) escribe/lee.
    // El {document=**} cubre el doc resumen consentLog/{uid} (el ack-proof NO
    // forjable que el gate de egreso lee) Y el log append-only consentLog/{uid}/events/*.
    // El doc vivo users/{uid}/settings/semanticSearch sigue client-writable (intención
    // de UX) pero su acknowledgedAt ya NO es la prueba — la prueba vive acá, fuera de
    // alcance del cliente.
    match /consentLog/{document=**} {
      allow read, write: if false;
    }
  }
}
