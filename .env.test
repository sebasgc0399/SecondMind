# Config DUMMY para el modo test (vitest). NO son secretos ni valores reales.
#
# Por qué existe: src/lib/firebase.ts inicializa Firebase en el top-level
# (getAuth) leyendo import.meta.env.VITE_FIREBASE_*. getAuth tira
# `auth/invalid-api-key` si la apiKey está vacía/ausente, así que cualquier
# test que importe transitivamente firebase.ts explota sin estas vars. Los
# unit tests son herméticos (mockean Firestore/Auth o no hacen llamadas de
# red), así que valores dummy no-vacíos alcanzan para que inicialice sin tirar.
#
# Antes esto dependía del .env.local del dev (gitignored) → pasaba local pero
# fallaba en CI. Commitearlo hace `npm test` reproducible en cualquier clone.
# vitest corre en mode 'test' y .env.test tiene mayor precedencia que .env.local,
# así que aplica igual local y en CI. Los valores reales (build/deploy) viven en
# .env.local (dev) y en los secrets del repo (release.yml) — acá NO.
VITE_FIREBASE_API_KEY=AIzaSyTEST-dummy-key-for-ci-unit-tests-0000
VITE_FIREBASE_AUTH_DOMAIN=secondmind-test.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=secondmind-test
VITE_FIREBASE_STORAGE_BUCKET=secondmind-test.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
VITE_FIREBASE_MEASUREMENT_ID=G-TEST00000
VITE_GOOGLE_OAUTH_CLIENT_ID=test-oauth-client-id.apps.googleusercontent.com
VITE_GOOGLE_OAUTH_CLIENT_SECRET=test-oauth-secret
VITE_GOOGLE_WEB_CLIENT_ID=test-web-client-id.apps.googleusercontent.com
