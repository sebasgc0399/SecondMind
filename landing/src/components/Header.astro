---
import { CTA_URL } from '../config';
---

<header class="hdr">
  <div class="container hdr-inner">
    <a class="brand" href="/" aria-label="SecondMind — inicio">
      <img src="/favicon.svg" alt="" width="26" height="26" />
      <span>SecondMind</span>
    </a>
    <a class="hdr-cta" href={CTA_URL}>Solicitar acceso</a>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklch, var(--background) 72%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .hdr-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.75rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }
  .brand img {
    width: 26px;
    height: 26px;
  }
  .hdr-cta {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--muted-foreground);
    padding: 0.45rem 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    transition:
      color 0.18s var(--ease),
      border-color 0.18s var(--ease),
      background 0.18s var(--ease);
  }
  .hdr-cta:hover {
    color: var(--foreground);
    border-color: color-mix(in oklch, var(--primary) 50%, var(--border-strong));
    background: color-mix(in oklch, var(--foreground) 5%, transparent);
  }
</style>
