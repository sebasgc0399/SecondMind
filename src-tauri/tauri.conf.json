{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SecondMind",
  "version": "0.1.5",
  "identifier": "com.secondmind.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SecondMind",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "capture",
        "title": "SecondMind — Captura rápida",
        "url": "/capture",
        "width": 480,
        "height": 220,
        "decorations": false,
        "alwaysOnTop": true,
        "center": true,
        "visible": false,
        "skipTaskbar": true,
        "resizable": false,
        "focus": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "ipc: http://ipc.localhost https://*.googleapis.com https://*.firebaseio.com wss://*.firebaseio.com https://*.firestore.googleapis.com https://firestore.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://www.googleapis.com https://apis.google.com",
        "script-src": "'self' 'unsafe-inline' https://apis.google.com",
        "style-src": "'self' 'unsafe-inline' https://fonts.googleapis.com",
        "font-src": "'self' https://fonts.gstatic.com",
        "img-src": "'self' data: https: blob:",
        "frame-src": "https://*.firebaseapp.com https://accounts.google.com"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sebasgc0399/SecondMind/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCQzNBQTgzMzczMzg5MDkKUldRSmlUTTNnNnJEYTNLNndkSThKNkZxbllYbTJLR3JPOENwTWxKcFFNZDduaDViaWZXS004NUgK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
